        <GodotPath></GodotPath>

        <!-- Uncomment and set if STS2 is not auto-detected -->
        <!-- <Sts2Path>/path/to/steamapps/common/Slay the Spire 2</Sts2Path> -->
    </PropertyGroup>
</Project>
